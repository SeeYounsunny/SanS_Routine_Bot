# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 알람을 보낼 그룹 채팅 ID (숫자만)
TELEGRAM_CHAT_ID=your_chat_id_here

# (선택) 1:1 루틴 입력 안내에 표시할 봇 유저네임. 미설정 시 sans_routine_bot
# TELEGRAM_BOT_USERNAME=sans_routine_bot

# Claude AI 요약용 (Anthropic API 키)
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# (선택) DB 파일 경로. 미설정 시 routines.db 사용
# DB_PATH=routines.db

# (선택) /reset 시 사용할 비밀번호. 미설정 시 0537
# RESET_PASSWORD=0537
